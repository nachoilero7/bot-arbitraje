# Polymarket CLOB API
CLOB_API_URL=https://clob.polymarket.com

# Proxy (opcional - usar si Polymarket está bloqueado por el ISP)
# Opción A: VPN con proxy local SOCKS5 (ej: Clash, V2Ray, etc.)
#   HTTPS_PROXY=socks5://127.0.0.1:1080
# Opción B: proxy HTTP local
#   HTTPS_PROXY=http://127.0.0.1:8080
# Opción C: VPN full-tunnel (TUN) → dejar vacío, el tráfico ya va por VPN
#   HTTPS_PROXY=

# The Odds API (enriquecimiento con bookmakers - free: 500 req/mes)
# Registro gratis en https://the-odds-api.com
# ODDS_API_KEY=60fd19939f168fa651f9dfc98d474c3c

# Polygon wallet (solo necesario para Phase 2 - ejecucion de trades)
# POLYGON_PRIVATE_KEY=0x...
# POLYGON_ADDRESS=0x...

# Scanner config
SCAN_INTERVAL_SECONDS=5
MIN_EDGE_THRESHOLD=0.03
MIN_LIQUIDITY_USD=100
FEE_RATE=0.02
