# ── Polymarket CLOB API ────────────────────────────────────────────────────────
# Get from https://polymarket.com/profile → API Keys
POLYGON_PRIVATE_KEY=<your_polygon_wallet_private_key>
POLYGON_ADDRESS=<your_polygon_wallet_address>
POLYGON_PROXY_ADDRESS=<gnosis_safe_proxy_wallet_from_polymarket>
CLOB_API_KEY=<clob_api_key>
CLOB_API_SECRET=<clob_api_secret>
CLOB_API_PASSPHRASE=<clob_api_passphrase>

# ── Risk management ────────────────────────────────────────────────────────────
DRY_RUN=true          # true = simulate only, false = real trades
BANKROLL_USD=100
MAX_POSITION_USD=20
MAX_DAILY_LOSS_USD=10
MIN_EDGE_TO_TRADE=0.04

# ── Scanner config ─────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=5
MIN_EDGE_THRESHOLD=0.03
MIN_LIQUIDITY_USD=100
FEE_RATE=0.02

# ── Optional enrichers ─────────────────────────────────────────────────────────
# The Odds API — https://the-odds-api.com (free: 500 req/month)
ODDS_API_KEY=

# AllSportsAPI2 via RapidAPI — https://rapidapi.com (free: 100 req/day)
RAPIDAPI_KEY=

# Finnhub — https://finnhub.io (free: 60 req/min)
FINNHUB_API_KEY=

# Alchemy — https://alchemy.com (free tier)
ALCHEMY_API_KEY=

# ── Telegram notifications ─────────────────────────────────────────────────────
# 1. Create bot via @BotFather → copy token
# 2. Send /start to your bot
# 3. https://api.telegram.org/bot{TOKEN}/getUpdates → copy "id" from chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_EDGE=0.05

# ── BTC Arb Monitor ────────────────────────────────────────────────────────────
MIN_EDGE_BTC=0.09

# ── Proxy (if Polymarket is blocked by ISP) ────────────────────────────────────
# HTTPS_PROXY=socks5://127.0.0.1:1080

# ── MiroFish (local LLM multi-agent server) ────────────────────────────────────
# See https://github.com/666ghj/MiroFish for setup
MIROFISH_URL=http://localhost:5001
MIROFISH_INTERVAL_SECS=3600
MIROFISH_MAX_MARKETS=2
MIROFISH_MIN_EDGE=0.08
